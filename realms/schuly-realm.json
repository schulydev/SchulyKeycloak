{
  "realm": "schuly",
  "enabled": true,
  "displayName": "Schuly",
  "loginTheme": "schuly",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "sslRequired": "external",
  "passwordPolicy": "passwordBlacklist(rockyou.txt) and notUsername(undefined) and notEmail(undefined) and notContainsUsername(undefined) and length(8)",
  "browserFlow": "browser-2fa",
  "roles": {
    "realm": [
      { "name": "Student", "description": "Schuly student" },
      { "name": "Teacher", "description": "Schuly teacher" },
      { "name": "Administrator", "description": "Schuly administrator" }
    ]
  },
  "groups": [
    { "name": "Student", "realmRoles": ["Student"] },
    { "name": "Teacher", "realmRoles": ["Teacher"] },
    { "name": "Administrator", "realmRoles": ["Administrator"] }
  ],
  "defaultDefaultClientScopes": ["groups"],
  "clientScopes": [
    {
      "name": "groups",
      "protocol": "openid-connect",
      "description": "Adds the user's group memberships as a `groups` claim.",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "schuly-app",
      "name": "Schuly App",
      "description": "Public OIDC client for the Schuly mobile app (PKCE).",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["schulytest://callback", "schuly://callback"],
      "webOrigins": ["+"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "defaultClientScopes": ["groups", "email", "profile", "roles", "web-origins"]
    }
  ],
  "authenticationFlows": [
    {
      "alias": "browser-2fa",
      "description": "Browser flow with mandatory 2FA: login with OTP or passkey, set up OTP if neither exists",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-cookie", "authenticatorFlow": false, "requirement": "ALTERNATIVE", "priority": 10, "userSetupAllowed": false },
        { "authenticator": "identity-provider-redirector", "authenticatorFlow": false, "requirement": "ALTERNATIVE", "priority": 20, "userSetupAllowed": false },
        { "authenticatorFlow": true, "requirement": "ALTERNATIVE", "priority": 30, "flowAlias": "browser-2fa-forms", "userSetupAllowed": false }
      ]
    },
    {
      "alias": "browser-2fa-forms",
      "description": "Username/password then mandatory MFA",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-username-password-form", "authenticatorFlow": false, "requirement": "REQUIRED", "priority": 10, "userSetupAllowed": false },
        { "authenticatorFlow": true, "requirement": "REQUIRED", "priority": 20, "flowAlias": "browser-2fa-mfa", "userSetupAllowed": false }
      ]
    },
    {
      "alias": "browser-2fa-mfa",
      "description": "Authenticate with an existing 2FA credential, or register one",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticatorFlow": true, "requirement": "ALTERNATIVE", "priority": 10, "flowAlias": "browser-2fa-authenticate", "userSetupAllowed": false },
        { "authenticatorFlow": true, "requirement": "ALTERNATIVE", "priority": 20, "flowAlias": "browser-2fa-register", "userSetupAllowed": false }
      ]
    },
    {
      "alias": "browser-2fa-authenticate",
      "description": "User has OTP or a passkey: let them use either",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "conditional-user-configured", "authenticatorFlow": false, "requirement": "REQUIRED", "priority": 10, "userSetupAllowed": false },
        { "authenticator": "auth-otp-form", "authenticatorFlow": false, "requirement": "ALTERNATIVE", "priority": 20, "userSetupAllowed": false },
        { "authenticator": "webauthn-authenticator-passwordless", "authenticatorFlow": false, "requirement": "ALTERNATIVE", "priority": 30, "userSetupAllowed": false }
      ]
    },
    {
      "alias": "browser-2fa-register",
      "description": "User has no 2FA yet: force OTP enrollment",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-otp-form", "authenticatorFlow": false, "requirement": "REQUIRED", "priority": 10, "userSetupAllowed": false }
      ]
    }
  ]
}
